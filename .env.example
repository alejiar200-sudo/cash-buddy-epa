# ====== Cash Buddy EPA - Variables de entorno ======
# Copia este archivo a .env y ajusta los valores.

# --- Base de datos PostgreSQL (local en el PC principal) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cashbuddy?schema=public"

# --- Servidor backend (Express) ---
# El backend sirve la API en /api y el frontend estático. Escucha en 0.0.0.0
# para permitir acceso remoto por Tailscale.
PORT=4000
HOST=0.0.0.0

# --- Autenticación JWT ---
# CAMBIA esto por una cadena larga y aleatoria en producción.
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# --- Usuario administrador inicial (seed) ---
ADMIN_EMAIL="admin@cashbuddy.local"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Administrador"

# --- Frontend (build time) ---
# URL base de la API que usa el frontend. En el modelo host (un solo puerto)
# se deja vacío para usar rutas relativas (/api).
NEXT_PUBLIC_API_URL=""
