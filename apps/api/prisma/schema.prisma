// Cash Buddy EPA - Esquema de base de datos
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS - Sistema original
// ============================================================

enum UserRole {
  admin
  user
}

enum WorkerRole {
  domiciliario
  administrativo
}

enum MovementType {
  ingreso
  egreso
}

enum Medium {
  cash
  bank
}

enum MovementStatus {
  pending
  confirmed
}

enum MovementKind {
  commission
  delivery
}

// ============================================================
// ENUMS - Sistema Shipday
// ============================================================

enum BaseType {
  entrega
  pago
}

enum ConversionType {
  banco_a_efectivo
  efectivo_a_banco
}

enum SyncStatus {
  ok
  error
  never
}

enum BankTxType {
  ingreso
  egreso
}

enum EditRequestStatus {
  pending
  approved
  rejected
}

enum ShiftSlot {
  AM
  PM
  close
}

// ============================================================
// MODELOS - Sistema original (sin cambios)
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(user)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  editRequests   EditRequest[] @relation("requester")
  reviewedEdits  EditRequest[] @relation("reviewer")
}

model EditRequest {
  id           String            @id @default(cuid())
  requesterId  String
  requestType  String            @default("edit") // "edit" | "delete"
  entityType   String            // "ShipdayOrder" | "Movement" | "BankTransaction" | etc.
  entityId     String            // ID del registro a editar/eliminar
  entityLabel  String            // Descripción legible: "Pedido #30 - $90.000"
  changes      Json              // { field: { old, new }, ... } — vacío si es delete
  reason       String
  status       EditRequestStatus @default(pending)
  reviewerId   String?
  reviewNotes  String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())

  requester User  @relation("requester", fields: [requesterId], references: [id])
  reviewer  User? @relation("reviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([requesterId])
}

model Settings {
  id                String   @id @default("singleton")
  companyName       String   @default("Epa")
  brandName         String   @default("Cash Buddy")
  logoData          String?   @db.Text  // Logo en base64 (data URL), se adapta solo
  termsAcceptedAt   DateTime?           // Fecha de aceptación de T&C (inicia garantía de 2 meses)
  initialCash       Int      @default(300000)
  initialBank       Int      @default(103130)
  setupComplete     Boolean  @default(false)
  commissionPercent Float    @default(0)
  // Porcentaje que cobra la empresa por cada domicilio Shipday
  shipdayCommission Float    @default(30)
  updatedAt         DateTime @updatedAt
}

model FieldNote {
  id        String   @id @default(cuid())
  date      String   @default("") // YYYY-MM-DD — día al que pertenece la nota
  content   String   @db.Text
  author    String?  // nombre de quien escribió
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([createdAt])
}

model Worker {
  id        String     @id @default(cuid())
  name      String
  role      WorkerRole @default(domiciliario)
  active    Boolean    @default(true)
  color     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  movements Movement[]
}

model Day {
  date        String   @id
  initialCash Int
  initialBank Int
  arqueoAM    Json?
  arqueoPM    Json?
  arqueoClose Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements Movement[]
}

model Movement {
  id            String         @id @default(cuid())
  date          String
  time          String
  category      Int
  type          MovementType
  medium        Medium
  amount        Int
  status        MovementStatus @default(confirmed)
  description   String?
  group         String?
  kind          MovementKind?
  deliveryId    String?
  deliveryValue Int?
  taxAmount     Int?
  createdBy     String?
  createdByName String?
  approvedBy    String?
  approvedByName String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())

  day      Day     @relation(fields: [date], references: [date], onDelete: Cascade)
  worker   Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId String?

  @@index([date])
  @@index([date, status])
  @@index([workerId])
  @@index([kind])
  @@index([status])
}

// ============================================================
// MODELOS - Sistema Shipday multi-sucursal
// ============================================================

model Branch {
  id          String     @id @default(cuid())
  name        String
  address     String?
  phone       String?
  apiKeyEnc   String     // API Key cifrada en AES-256
  active      Boolean    @default(true)
  syncStatus  SyncStatus @default(never)
  syncMessage String?
  lastSyncAt  DateTime?
  ordersSince DateTime?  // Solo se cargan pedidos entregados DESDE esta fecha (día de arranque)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  drivers     Driver[]
  orders      ShipdayOrder[]
  bases       BaseTransaction[]
  conversions Conversion[]
  closes      MonthlyClose[]
  dailyStats  DailyDriverStat[]
}

model Driver {
  id              String   @id @default(cuid())
  shipdayDriverId String
  branchId        String
  name            String
  phone           String?
  email           String?
  active          Boolean  @default(true)
  pendingDebt     Int      @default(0)
  creditAmount    Int      @default(0)
  creditMedium    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch     Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders     ShipdayOrder[]
  bases      BaseTransaction[]
  payments   DriverPayment[]
  dailyStats DailyDriverStat[]

  @@unique([shipdayDriverId, branchId])
  @@index([branchId])
  @@index([pendingDebt])
}

model ShipdayOrder {
  id              String    @id @default(cuid())
  shipdayOrderId  String    @unique
  branchId        String
  driverId        String?
  orderNumber     String?
  deliveryValue   Int       @default(0)
  companyAmount   Int       @default(0)
  customerName    String?
  customerAddress String?
  status          String
  deliveredAt     DateTime?
  rawData         Json?
  clientId        String?
  addToClientDebt Boolean   @default(false)
  createdAt       DateTime  @default(now())

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  driver  Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)
  client  Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([branchId, status])
  @@index([driverId])
  @@index([deliveredAt])
  @@index([status])
}

model BaseTransaction {
  id         String   @id @default(cuid())
  branchId   String
  driverId   String
  amount     Int
  cashAmount Int      @default(0)
  bankAmount Int      @default(0)
  type       BaseType
  notes      String?
  createdBy     String?
  createdByName String?
  date       DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([driverId])
  @@index([driverId, type])
  @@index([date])
}

model DriverPayment {
  id       String   @id @default(cuid())
  driverId String
  branchId String
  amount   Int
  medium   Medium   @default(cash)
  notes    String?
  createdBy     String?
  createdByName String?
  date     DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([branchId])
}

model Conversion {
  id         String         @id @default(cuid())
  branchId   String
  amount     Int
  type       ConversionType
  notes      String?
  userId     String?
  userName   String?
  driverId   String?        // domiciliario asociado (opcional)
  driverName String?        // nombre cacheado para historial
  date       DateTime       @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([date])
  @@index([driverId])
}

model DailyDriverStat {
  id           String @id @default(cuid())
  date         String // YYYY-MM-DD
  branchId     String
  driverId     String
  orderCount   Int    @default(0)
  totalValue   Int    @default(0)
  companyTotal Int    @default(0)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([date, driverId])
  @@index([branchId])
  @@index([date])
  @@index([date, branchId])
}

model MonthlyClose {
  id              String   @id @default(cuid())
  branchId        String?
  month           String   // YYYY-MM
  totalOrders     Int
  totalValue      Int
  companyTotal    Int
  basesGiven      Int
  basesPaid       Int
  basesPending    Int
  conversions     Json
  snapshot        Json
  initialCash     Int?
  initialBank     Int?
  // Indicadores del reporte mensual (estilo Excel)
  totalSales        Int?
  totalExpenses     Int?
  totalPayroll      Int?
  transferDiff      Int?
  clientDebtBalance Int?
  netProfit         Int?
  profitability     Float?
  closedBy          String?
  closedByName      String?
  closedAt        DateTime @default(now())
  locked          Boolean  @default(true) // bloqueado al cerrarse; modificarlo requiere EditRequest

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([month, branchId])
  @@index([month])
}

// ============================================================
// NUEVOS MODELOS
// ============================================================

model Client {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  address     String?
  notes       String?
  pendingDebt Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  debts  ClientDebt[]
  orders ShipdayOrder[]
}

model ClientDebt {
  id          String   @id @default(cuid())
  clientId    String
  description String
  amount      Int
  paid        Boolean  @default(false)
  paidAt      DateTime?
  paidAmount  Int?
  paidCash    Int      @default(0)
  paidBank    Int      @default(0)
  createdBy     String?
  createdByName String?
  paidBy        String?
  paidByName    String?
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, paid])
  @@index([paid])
}

model BankTransaction {
  id          String     @id @default(cuid())
  type        BankTxType
  medium      Medium     @default(bank) // efectivo o transferencia(banco)
  amount      Int
  description String
  reference   String?
  driverId    String?    // domiciliario asociado (opcional, solo trazabilidad)
  driverName  String?    // nombre cacheado para historial
  groupId     String?    // enlaza las dos mitades de un movimiento mixto (efectivo+transferencia)
  pairId      String?    // enlaza un movimiento con su contraparte (salida ↔ retorno) de forma explícita
  noCounterpart Boolean  @default(false) // marcado explícito: este movimiento NO requiere contraparte
  createdBy     String?
  createdByName String?
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())

  @@index([date])
  @@index([type])
  @@index([driverId])
  @@index([groupId])
  @@index([pairId])
}

model ShiftClose {
  id          String     @id @default(cuid())
  date        String     // YYYY-MM-DD
  shift       ShiftSlot
  receivedBy  String?
  handedBy    String?
  denominations Json
  totalCounted  Int
  totalExpected Int
  difference    Int
  notes         String?
  createdBy     String?
  createdByName String?
  // Edición autorizada de cierres
  editedBy      String?
  editedByName  String?
  editedAt      DateTime?
  closedAt    DateTime   @default(now())
  locked      Boolean    @default(true) // bloqueado al registrarse; modificarlo requiere EditRequest

  @@unique([date, shift])
  @@index([date])
}
