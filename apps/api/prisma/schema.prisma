// Cash Buddy EPA - Esquema de base de datos
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS - Sistema original
// ============================================================

enum UserRole {
  admin
  user
}

enum WorkerRole {
  domiciliario
  administrativo
}

enum MovementType {
  ingreso
  egreso
}

enum Medium {
  cash
  bank
}

enum MovementStatus {
  pending
  confirmed
}

enum MovementKind {
  commission
  delivery
}

// ============================================================
// ENUMS - Sistema Shipday
// ============================================================

enum BaseType {
  entrega
  pago
}

enum ConversionType {
  banco_a_efectivo
  efectivo_a_banco
}

enum SyncStatus {
  ok
  error
  never
}

// ============================================================
// MODELOS - Sistema original (sin cambios)
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(user)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Settings {
  id                String   @id @default("singleton")
  companyName       String   @default("Epa")
  initialCash       Int      @default(300000)
  initialBank       Int      @default(103130)
  setupComplete     Boolean  @default(false)
  commissionPercent Float    @default(0)
  // Porcentaje que cobra la empresa por cada domicilio Shipday
  shipdayCommission Float    @default(30)
  updatedAt         DateTime @updatedAt
}

model Worker {
  id        String     @id @default(cuid())
  name      String
  role      WorkerRole @default(domiciliario)
  active    Boolean    @default(true)
  color     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  movements Movement[]
}

model Day {
  date        String   @id
  initialCash Int
  initialBank Int
  arqueoAM    Json?
  arqueoPM    Json?
  arqueoClose Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements Movement[]
}

model Movement {
  id            String         @id @default(cuid())
  date          String
  time          String
  category      Int
  type          MovementType
  medium        Medium
  amount        Int
  status        MovementStatus @default(confirmed)
  description   String?
  group         String?
  kind          MovementKind?
  deliveryId    String?
  deliveryValue Int?
  createdAt     DateTime       @default(now())

  day      Day     @relation(fields: [date], references: [date], onDelete: Cascade)
  worker   Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId String?

  @@index([date])
  @@index([workerId])
  @@index([kind])
}

// ============================================================
// MODELOS - Sistema Shipday multi-sucursal
// ============================================================

model Branch {
  id          String     @id @default(cuid())
  name        String
  address     String?
  phone       String?
  apiKeyEnc   String     // API Key cifrada en AES-256
  active      Boolean    @default(true)
  syncStatus  SyncStatus @default(never)
  syncMessage String?
  lastSyncAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  drivers     Driver[]
  orders      ShipdayOrder[]
  bases       BaseTransaction[]
  conversions Conversion[]
  closes      MonthlyClose[]
  dailyStats  DailyDriverStat[]
}

model Driver {
  id              String   @id @default(cuid())
  shipdayDriverId String
  branchId        String
  name            String
  phone           String?
  email           String?
  active          Boolean  @default(true)
  pendingDebt     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch     Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders     ShipdayOrder[]
  bases      BaseTransaction[]
  payments   DriverPayment[]
  dailyStats DailyDriverStat[]

  @@unique([shipdayDriverId, branchId])
  @@index([branchId])
}

model ShipdayOrder {
  id              String    @id @default(cuid())
  shipdayOrderId  String    @unique
  branchId        String
  driverId        String?
  orderNumber     String?
  deliveryValue   Int       @default(0)
  companyAmount   Int       @default(0)
  customerName    String?
  customerAddress String?
  status          String
  deliveredAt     DateTime?
  rawData         Json?
  createdAt       DateTime  @default(now())

  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  driver Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([driverId])
  @@index([deliveredAt])
  @@index([status])
}

model BaseTransaction {
  id       String   @id @default(cuid())
  branchId String
  driverId String
  amount   Int
  type     BaseType
  notes    String?
  date     DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([driverId])
  @@index([date])
}

model DriverPayment {
  id       String   @id @default(cuid())
  driverId String
  branchId String
  amount   Int
  medium   Medium   @default(cash)
  notes    String?
  date     DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([branchId])
}

model Conversion {
  id       String         @id @default(cuid())
  branchId String
  amount   Int
  type     ConversionType
  notes    String?
  userId   String?
  date     DateTime       @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([date])
}

model DailyDriverStat {
  id           String @id @default(cuid())
  date         String // YYYY-MM-DD
  branchId     String
  driverId     String
  orderCount   Int    @default(0)
  totalValue   Int    @default(0)
  companyTotal Int    @default(0)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([date, driverId])
  @@index([branchId])
  @@index([date])
}

model MonthlyClose {
  id           String   @id @default(cuid())
  branchId     String?
  month        String   // YYYY-MM
  totalOrders  Int
  totalValue   Int
  companyTotal Int
  basesGiven   Int
  basesPaid    Int
  basesPending Int
  conversions  Json
  snapshot     Json
  closedAt     DateTime @default(now())

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([month, branchId])
  @@index([month])
}
